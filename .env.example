# StreamGuard Environment Variables

# Port for the server
PORT=3000

# PostgreSQL Database
# For local: postgresql://postgres:password@localhost:5432/streamguard
# For Railway: automatically provided as DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/streamguard

# Your Saweria stream key (from overlay URL: saweria.co/widgets/alert?streamKey=THIS_PART)
# Note: only needed for signature verification (currently disabled)
SAWERIA_STREAM_KEY=your_stream_key_here
